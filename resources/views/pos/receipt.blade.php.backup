    <script>
        function printThermal() {
            const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

            fetch('{{ route('pos.receipt.print', $sale) }}', {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'X-CSRF-TOKEN': csrfToken
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Receipt sent to thermal printer!');
                } else {
                    alert('Failed to print: ' + data.message);
                }
            })
            .catch(error => {
                alert('Error: ' + error.message);
            });
        }

        function sendViaWhatsApp() {
            // Use pre-formatted phone number from controller
            const phone = "{{ $whatsappPhone ?? '' }}";

            // Validate phone number
            if (!phone) {
                alert('Customer phone number not available');
                return;
            }

            if (phone.length < 10 || phone.length > 15) {
                alert('Phone number appears to be invalid. Please check customer details.');
                return;
            }

            // Build receipt message
            const message = buildWhatsAppMessage();

            // Encode message for URL
            const encodedMessage = encodeURIComponent(message);

            // Build WhatsApp Web URL
            const whatsappUrl = `https://web.whatsapp.com/send?phone=${phone}&text=${encodedMessage}`;

            // Open in new window
            window.open(whatsappUrl, '_blank');
        }

        function buildWhatsAppMessage() {
            const businessName = "{{ $businessName }}";
            const saleNumber = "{{ $sale->sale_number }}";
            const customerName = "{{ $sale->customer?->full_name ?? 'Customer' }}";
            const total = "{{ $currencySymbol }}{{ number_format($sale->total_amount, 2) }}";
            const receiptUrl = "{{ url('/pos/receipt/' . $sale->id) }}";

            // Build items summary
            let itemsList = "";
            @foreach($sale->items as $item)
            itemsList += "• {{ $item->quantity }}x {{ $item->item_name }} - {{ $currencySymbol }}{{ number_format($item->line_total, 2) }}\n";
            @endforeach

            // Format message
            const message = `🧾 *Receipt from ${businessName}*\n\n` +
                           `Dear ${customerName},\n\n` +
                           `Thank you for your purchase!\n\n` +
                           `*Receipt #:* ${saleNumber}\n` +
                           `*Date:* {{ $sale->sale_date->format('M d, Y g:i A') }}\n\n` +
                           `*Items:*\n${itemsList}\n` +
                           `*Total Amount:* ${total}\n\n` +
                           `View detailed receipt: ${receiptUrl}\n\n` +
                           `Thank you for your business! 🙏`;

            return message;
        }
    </script>
</body>
</html>
